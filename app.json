{
  "expo": {
    "name": "NOWHERE",
    "slug": "nowhere-nowhere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nowhere.nowhere",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NOWHERE uses your location to auto-play music when you arrive at saved places.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NOWHERE uses your location in the background to auto-play music when you arrive at saved places.",
        "NSLocationAlwaysUsageDescription": "NOWHERE uses your location in the background to auto-play music when you arrive at saved places.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.nowhere.nowhere",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location"
    ]
  }
}
