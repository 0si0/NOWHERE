rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function isShortString(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function isCoordinatesMap(data) {
      return data.keys().hasAll(['latitude', 'longitude']) &&
        data.keys().hasOnly(['latitude', 'longitude']) &&
        isNumber(data.latitude) &&
        isNumber(data.longitude) &&
        data.latitude >= -90 &&
        data.latitude <= 90 &&
        data.longitude >= -180 &&
        data.longitude <= 180;
    }

    function isPlaylistMap(data) {
      return data.keys().hasAll(['provider', 'playlistId', 'title', 'artworkUrl']) &&
        data.keys().hasOnly(['provider', 'playlistId', 'title', 'artworkUrl']) &&
        isShortString(data.provider, 20) &&
        (data.provider == 'spotify' || data.provider == 'unknown') &&
        isShortString(data.playlistId, 120) &&
        isShortString(data.title, 120) &&
        isShortString(data.artworkUrl, 500);
    }

    function isNullableString(value, maxLength) {
      return value == null || isShortString(value, maxLength);
    }

    function isPlayTargetMap(data) {
      return data == null || (
        data.keys().hasAll([
          'type',
          'provider',
          'id',
          'spotifyUri',
          'title',
          'artist',
          'album',
          'artworkUrl',
          'durationMs'
        ]) &&
        data.keys().hasOnly([
          'type',
          'provider',
          'id',
          'spotifyUri',
          'title',
          'artist',
          'album',
          'artworkUrl',
          'durationMs'
        ]) &&
        (data.type == 'track' || data.type == 'playlist') &&
        (data.provider == 'spotify' || data.provider == 'unknown') &&
        isShortString(data.id, 180) &&
        isNullableString(data.spotifyUri, 240) &&
        isShortString(data.title, 160) &&
        isNullableString(data.artist, 160) &&
        isNullableString(data.album, 160) &&
        isNullableString(data.artworkUrl, 500) &&
        isNumber(data.durationMs) &&
        data.durationMs >= 0
      );
    }

    function isFavoriteArtistMap(data) {
      return data.keys().hasAll(['id', 'spotifyId', 'name', 'spotifyUri', 'uri', 'artworkUrl', 'imageUrl', 'popularity', 'genres']) &&
        data.keys().hasOnly(['id', 'spotifyId', 'name', 'spotifyUri', 'uri', 'artworkUrl', 'imageUrl', 'popularity', 'genres']) &&
        isShortString(data.id, 120) &&
        isShortString(data.spotifyId, 120) &&
        isShortString(data.name, 160) &&
        isShortString(data.spotifyUri, 240) &&
        isShortString(data.uri, 240) &&
        isShortString(data.artworkUrl, 500) &&
        isShortString(data.imageUrl, 500) &&
        isNumber(data.popularity) &&
        data.popularity >= 0 &&
        data.popularity <= 100 &&
        data.genres is list &&
        data.genres.size() <= 6;
    }

    function isFavoriteArtistsList(artists) {
      return artists is list &&
        artists.size() <= 3 &&
        (artists.size() < 1 || isFavoriteArtistMap(artists[0])) &&
        (artists.size() < 2 || isFavoriteArtistMap(artists[1])) &&
        (artists.size() < 3 || isFavoriteArtistMap(artists[2]));
    }

    function isSavedPlace(data, userId) {
      return data.keys().hasAll([
        'userId',
        'name',
        'radiusMeters',
        'coordinates',
        'geohash',
        'playlist',
        'playTarget',
        'weatherRules',
        'timeRules',
        'status',
        'source',
        'createdAt',
        'updatedAt'
      ]) &&
        data.keys().hasOnly([
        'userId',
        'name',
        'radiusMeters',
        'coordinates',
        'geohash',
        'playlist',
        'playTarget',
        'weatherRules',
        'timeRules',
        'status',
        'source',
        'createdAt',
        'updatedAt'
      ]) &&
        data.userId == userId &&
        isShortString(data.name, 60) &&
        (data.radiusMeters == 50 || data.radiusMeters == 100 || data.radiusMeters == 200 || data.radiusMeters == 300) &&
        isCoordinatesMap(data.coordinates) &&
        isShortString(data.geohash, 12) &&
        isPlaylistMap(data.playlist) &&
        isPlayTargetMap(data.playTarget) &&
        data.weatherRules is list &&
        data.weatherRules.size() <= 8 &&
        data.timeRules is list &&
        data.timeRules.size() <= 8 &&
        (data.status == 'active' || data.status == 'archived') &&
        isShortString(data.source, 40);
    }

    function isPlayRecord(data, userId) {
      return data.keys().hasAll([
        'userId',
        'trackId',
        'title',
        'artist',
        'albumArtUrl',
        'provider',
        'placeName',
        'savedPlaceId',
        'location',
        'playedAt',
        'createdAt'
      ]) &&
        data.keys().hasOnly([
        'userId',
        'trackId',
        'title',
        'artist',
        'albumArtUrl',
        'provider',
        'placeName',
        'savedPlaceId',
        'location',
        'playedAt',
        'createdAt'
      ]) &&
        data.userId == userId &&
        isShortString(data.trackId, 160) &&
        isShortString(data.title, 160) &&
        isShortString(data.artist, 160) &&
        isShortString(data.albumArtUrl, 500) &&
        isShortString(data.provider, 20) &&
        isShortString(data.placeName, 80) &&
        isShortString(data.savedPlaceId, 160) &&
        data.location.keys().hasAll(['latitude', 'longitude', 'geohash']) &&
        data.location.keys().hasOnly(['latitude', 'longitude', 'geohash']) &&
        (data.location.latitude == null || isNumber(data.location.latitude)) &&
        (data.location.longitude == null || isNumber(data.location.longitude)) &&
        isShortString(data.location.geohash, 12);
    }

    function isChallengeMap(data) {
      return data.keys().hasAll(['genre', 'country', 'mood', 'request']) &&
        data.keys().hasOnly(['genre', 'country', 'mood', 'request']) &&
        isShortString(data.genre, 40) &&
        isShortString(data.country, 40) &&
        isShortString(data.mood, 40) &&
        isShortString(data.request, 30);
    }

    function isListeningContext(data) {
      return data.keys().hasAll([
        'timeBucket',
        'hour',
        'weatherCondition',
        'weatherMood',
        'placeName',
        'savedPlaceId',
        'geohash',
        'location'
      ]) &&
        data.keys().hasOnly([
        'timeBucket',
        'hour',
        'weatherCondition',
        'weatherMood',
        'placeName',
        'savedPlaceId',
        'geohash',
        'location'
      ]) &&
        isShortString(data.timeBucket, 40) &&
        data.hour is int &&
        data.hour >= 0 &&
        data.hour <= 23 &&
        isShortString(data.weatherCondition, 40) &&
        isShortString(data.weatherMood, 60) &&
        isShortString(data.placeName, 80) &&
        isShortString(data.savedPlaceId, 160) &&
        isShortString(data.geohash, 12) &&
        data.location.keys().hasAll(['latitude', 'longitude']) &&
        data.location.keys().hasOnly(['latitude', 'longitude']) &&
        (data.location.latitude == null || isNumber(data.location.latitude)) &&
        (data.location.longitude == null || isNumber(data.location.longitude));
    }

    function isListeningEvent(data, userId) {
      return data.keys().hasAll([
        'userId',
        'eventType',
        'source',
        'recommendationSlot',
        'track',
        'context',
        'challenge',
        'occurredAt',
        'createdAt'
      ]) &&
        data.keys().hasOnly([
        'userId',
        'eventType',
        'source',
        'recommendationSlot',
        'track',
        'context',
        'challenge',
        'occurredAt',
        'createdAt'
      ]) &&
        data.userId == userId &&
        isShortString(data.eventType, 40) &&
        isShortString(data.source, 40) &&
        isShortString(data.recommendationSlot, 40) &&
        isPlayTargetMap(data.track) &&
        isListeningContext(data.context) &&
        isChallengeMap(data.challenge) &&
        isShortString(data.occurredAt, 64);
    }

    function isMusicMapLocation(data) {
      return data.keys().hasAll(['latitude', 'longitude', 'geohash']) &&
        data.keys().hasOnly(['latitude', 'longitude', 'geohash']) &&
        isNumber(data.latitude) &&
        isNumber(data.longitude) &&
        data.latitude >= -90 &&
        data.latitude <= 90 &&
        data.longitude >= -180 &&
        data.longitude <= 180 &&
        isShortString(data.geohash, 12);
    }

    function isMusicMapRecord(data, userId) {
      return data.keys().hasAll([
        'userId',
        'schemaVersion',
        'recordType',
        'source',
        'sessionId',
        'track',
        'albumColor',
        'albumArtUrl',
        'placeName',
        'location',
        'routePoints',
        'routeSegments',
        'playedDurationMs',
        'startedAt',
        'recordedAt',
        'createdAt'
      ]) &&
        data.keys().hasOnly([
        'userId',
        'schemaVersion',
        'recordType',
        'source',
        'sessionId',
        'track',
        'albumColor',
        'albumArtUrl',
        'placeName',
        'location',
        'routePoints',
        'routeSegments',
        'playedDurationMs',
        'startedAt',
        'recordedAt',
        'createdAt'
      ]) &&
        data.userId == userId &&
        data.schemaVersion is int &&
        (data.recordType == 'pin' || data.recordType == 'track') &&
        isShortString(data.source, 40) &&
        isShortString(data.sessionId, 80) &&
        isPlayTargetMap(data.track) &&
        isShortString(data.albumColor, 12) &&
        isShortString(data.albumArtUrl, 500) &&
        isShortString(data.placeName, 80) &&
        isMusicMapLocation(data.location) &&
        data.routePoints is list &&
        data.routePoints.size() <= 160 &&
        data.routeSegments is list &&
        data.routeSegments.size() <= 120 &&
        isNumber(data.playedDurationMs) &&
        data.playedDurationMs >= 0 &&
        isShortString(data.startedAt, 64) &&
        isShortString(data.recordedAt, 64);
    }

    function isMusicMapPublicRecord(data) {
      return data.keys().hasAll([
        'schemaVersion',
        'recordType',
        'source',
        'track',
        'albumColor',
        'albumArtUrl',
        'placeName',
        'location',
        'routePoints',
        'playedDurationMs',
        'startedAt',
        'recordedAt',
        'createdAt'
      ]) &&
        data.keys().hasOnly([
        'schemaVersion',
        'recordType',
        'source',
        'track',
        'albumColor',
        'albumArtUrl',
        'placeName',
        'location',
        'routePoints',
        'playedDurationMs',
        'startedAt',
        'recordedAt',
        'createdAt'
      ]) &&
        data.schemaVersion is int &&
        (data.recordType == 'pin' || data.recordType == 'track') &&
        isShortString(data.source, 40) &&
        isPlayTargetMap(data.track) &&
        isShortString(data.albumColor, 12) &&
        isShortString(data.albumArtUrl, 500) &&
        isShortString(data.placeName, 80) &&
        isMusicMapLocation(data.location) &&
        data.routePoints is list &&
        data.routePoints.size() <= 160 &&
        isNumber(data.playedDurationMs) &&
        data.playedDurationMs >= 0 &&
        isShortString(data.startedAt, 64) &&
        isShortString(data.recordedAt, 64);
    }

    function isConsent(data, userId, consentId) {
      return data.keys().hasAll([
        'userId',
        'consentType',
        'granted',
        'version',
        'updatedAt'
      ]) &&
        data.keys().hasOnly([
        'userId',
        'consentType',
        'granted',
        'version',
        'updatedAt'
      ]) &&
        data.userId == userId &&
        data.consentType == consentId &&
        data.granted is bool &&
        isShortString(data.version, 20);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        request.resource.data.keys().hasAll([
          'userId',
          'uid',
          'isAnonymous',
          'lastLoginAt',
          'profileVersion',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'userId',
          'uid',
          'isAnonymous',
          'email',
          'emailVerified',
          'displayName',
          'nickname',
          'photoURL',
          'authProvider',
          'favoriteArtists',
          'favoriteArtistsUpdatedAt',
          'lastLoginAt',
          'profileVersion',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.userId == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.isAnonymous is bool &&
        request.resource.data.profileVersion is int &&
        isShortString(request.resource.data.lastLoginAt, 64) &&
        (!request.resource.data.keys().hasAny(['email']) || isShortString(request.resource.data.email, 254)) &&
        (!request.resource.data.keys().hasAny(['emailVerified']) || request.resource.data.emailVerified is bool) &&
        (!request.resource.data.keys().hasAny(['displayName']) || isShortString(request.resource.data.displayName, 80)) &&
        (!request.resource.data.keys().hasAny(['nickname']) || isShortString(request.resource.data.nickname, 80)) &&
        (!request.resource.data.keys().hasAny(['photoURL']) || isShortString(request.resource.data.photoURL, 500)) &&
        (!request.resource.data.keys().hasAny(['authProvider']) || isShortString(request.resource.data.authProvider, 40)) &&
        (!request.resource.data.keys().hasAny(['favoriteArtists']) || isFavoriteArtistsList(request.resource.data.favoriteArtists)) &&
        (!request.resource.data.keys().hasAny(['favoriteArtistsUpdatedAt']) || request.resource.data.favoriteArtistsUpdatedAt is timestamp);

      match /savedPlaces/{placeId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isSavedPlace(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      match /playHistory/{recordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isPlayRecord(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      match /listeningEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isListeningEvent(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      match /musicMapRecords/{recordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isMusicMapRecord(request.resource.data, userId);
        allow delete: if isOwner(userId);
      }

      match /consents/{consentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isConsent(request.resource.data, userId, consentId);
      }
    }

    match /musicMapPublicRecords/{recordId} {
      allow read: if signedIn();
      allow create: if signedIn() && isMusicMapPublicRecord(request.resource.data);
      allow update, delete: if false;
    }
  }
}
