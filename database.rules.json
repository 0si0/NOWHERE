{
  "rules": {
    ".read": false,
    ".write": false,
    "vibes": {
      "$geohash": {
        ".read": "auth != null",
        ".indexOn": ["updatedAt"],
        "$sessionId": {
          ".write": "auth != null && ((!newData.exists() && data.child('uid').val() === auth.uid) || newData.child('uid').val() === auth.uid)",
          "uid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "geohash": {
            ".validate": "newData.isString() && newData.val().length <= 12"
          },
          "sessionId": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          },
          "nickname": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
          },
          "trackId": {
            ".validate": "newData.isString() && newData.val().length <= 160"
          },
          "trackTitle": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160"
          },
          "trackArtist": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 160"
          },
          "provider": {
            ".validate": "newData.isString() && (newData.val() === 'spotify' || newData.val() === 'unknown')"
          },
          "createdAt": {
            ".validate": true
          },
          "updatedAt": {
            ".validate": true
          },
          "$other": {
            ".validate": false
          }
        }
      }
    }
  }
}
